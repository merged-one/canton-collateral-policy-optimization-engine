# Control Plane Quickstart overlay profile: faithful
# Mirrors upstream configureProfiles defaults as closely as practical.
OBSERVABILITY_ENABLED=true
AUTH_MODE=oauth2
PARTY_HINT=__PARTY_HINT__
TEST_MODE=off
DOCKER_NETWORK=quickstart-control-plane
PARTICIPANT_LEDGER_API_PORT_SUFFIX=911
PARTICIPANT_ADMIN_API_PORT_SUFFIX=912
PARTICIPANT_JSON_API_PORT_SUFFIX=976
VALIDATOR_ADMIN_API_PORT_SUFFIX=913
CANTON_HTTP_HEALTHCHECK_PORT_SUFFIX=910
