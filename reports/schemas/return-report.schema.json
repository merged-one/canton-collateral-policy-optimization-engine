{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://canton-collateral-control-plane.dev/reports/return-report.schema.json",
  "title": "Return Report v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reportType",
    "reportVersion",
    "returnReportId",
    "generatedAt",
    "overallStatus",
    "demo",
    "artifacts",
    "scenarios",
    "timeline",
    "invariantChecks"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri-reference"
    },
    "reportType": {
      "const": "ReturnReport"
    },
    "reportVersion": {
      "const": "0.1.0"
    },
    "returnReportId": {
      "type": "string",
      "pattern": "^rrr-[0-9a-f]{16}$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "overallStatus": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "demo": {
      "$ref": "#/$defs/demo"
    },
    "artifacts": {
      "$ref": "#/$defs/artifacts"
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scenario"
      }
    },
    "timeline": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/timelineEntry"
      }
    },
    "invariantChecks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/invariantCheck"
      }
    }
  },
  "$defs": {
    "pathString": {
      "type": "string",
      "minLength": 1
    },
    "identifier": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "demo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "demoId",
        "demoVersion",
        "runtimeMode",
        "command",
        "manifestPath",
        "outputDirectory",
        "primaryOptimizationArtifact",
        "scenarioCount",
        "positiveScenarioCount",
        "negativeScenarioCount"
      ],
      "properties": {
        "demoId": {
          "$ref": "#/$defs/identifier"
        },
        "demoVersion": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "runtimeMode": {
          "type": "string",
          "enum": [
            "IDE_LEDGER",
            "QUICKSTART"
          ]
        },
        "command": {
          "type": "string",
          "enum": [
            "make demo-return",
            "make demo-return-quickstart"
          ]
        },
        "manifestPath": {
          "$ref": "#/$defs/pathString"
        },
        "outputDirectory": {
          "$ref": "#/$defs/pathString"
        },
        "primaryOptimizationArtifact": {
          "$ref": "#/$defs/pathString"
        },
        "scenarioCount": {
          "type": "integer",
          "minimum": 1
        },
        "positiveScenarioCount": {
          "type": "integer",
          "minimum": 1
        },
        "negativeScenarioCount": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "returnReportPath",
        "markdownSummaryPath",
        "timelinePath"
      ],
      "properties": {
        "returnReportPath": {
          "$ref": "#/$defs/pathString"
        },
        "markdownSummaryPath": {
          "$ref": "#/$defs/pathString"
        },
        "timelinePath": {
          "$ref": "#/$defs/pathString"
        }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenarioId",
        "mode",
        "description",
        "result",
        "summary",
        "observedReasonCodes",
        "expectedReasonCodes",
        "policyEvaluationReportPath",
        "optimizationReportPath",
        "workflowInputPath",
        "workflowResultPath",
        "quickstartSeedReceiptPath",
        "adapterExecutionReportPath",
        "adapterStatusPath",
        "workflowRuntime",
        "policyDecision",
        "optimizationStatus",
        "currentPostedLotIds",
        "retainedLotIds",
        "returnLotIds",
        "requestedReturnQuantity",
        "remainingRequiredCoverage",
        "blockedPhase",
        "adapterOutcome",
        "requestIdentifier",
        "approvalState",
        "releaseAction",
        "finalPostReturnState",
        "replayHandlingResult",
        "workflow"
      ],
      "properties": {
        "scenarioId": {
          "$ref": "#/$defs/identifier"
        },
        "mode": {
          "type": "string",
          "enum": [
            "POSITIVE",
            "NEGATIVE"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "result": {
          "type": "string",
          "enum": [
            "SUCCESS",
            "EXPECTED_FAILURE"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "observedReasonCodes": {
          "$ref": "#/$defs/stringArray"
        },
        "expectedReasonCodes": {
          "$ref": "#/$defs/stringArray"
        },
        "policyEvaluationReportPath": {
          "$ref": "#/$defs/pathString"
        },
        "optimizationReportPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "workflowInputPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "workflowResultPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "quickstartSeedReceiptPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "adapterExecutionReportPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "adapterStatusPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "workflowRuntime": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "IDE_LEDGER",
            "QUICKSTART",
            null
          ]
        },
        "policyDecision": {
          "type": "string",
          "enum": [
            "ACCEPT",
            "REJECT",
            "ESCALATE",
            "REVIEW"
          ]
        },
        "optimizationStatus": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "OPTIMAL",
            "NO_SOLUTION",
            null
          ]
        },
        "currentPostedLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "retainedLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "returnLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "requestedReturnQuantity": {
          "type": [
            "number",
            "null"
          ]
        },
        "remainingRequiredCoverage": {
          "type": [
            "number",
            "null"
          ]
        },
        "blockedPhase": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "POLICY_EVALUATION",
            "OPTIMIZATION",
            "WORKFLOW",
            "ADAPTER",
            null
          ]
        },
        "adapterOutcome": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "EXECUTED",
            "BLOCKED",
            "NOT_REQUESTED",
            null
          ]
        },
        "requestIdentifier": {
          "type": [
            "string",
            "null"
          ]
        },
        "approvalState": {
          "type": [
            "object",
            "null"
          ],
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/approvalState"
            }
          ]
        },
        "releaseAction": {
          "type": [
            "object",
            "null"
          ],
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/releaseAction"
            }
          ]
        },
        "finalPostReturnState": {
          "type": [
            "object",
            "null"
          ],
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/finalPostReturnState"
            }
          ]
        },
        "replayHandlingResult": {
          "type": [
            "object",
            "null"
          ],
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/replayHandlingResult"
            }
          ]
        },
        "workflow": {
          "type": [
            "object",
            "null"
          ],
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/workflowResult"
            }
          ]
        }
      }
    },
    "approvalState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "securedPartyApproval",
        "custodianApproval",
        "workflowGate",
        "releaseConditionSatisfied"
      ],
      "properties": {
        "securedPartyApproval": {
          "type": "string",
          "minLength": 1
        },
        "custodianApproval": {
          "type": "string",
          "minLength": 1
        },
        "workflowGate": {
          "type": [
            "string",
            "null"
          ]
        },
        "releaseConditionSatisfied": {
          "type": "boolean"
        }
      }
    },
    "releaseAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "settlementInstructionId",
        "settlementInstructionState",
        "settlementAction",
        "adapterReceiptStatus",
        "adapterMovementLotIds"
      ],
      "properties": {
        "settlementInstructionId": {
          "type": [
            "string",
            "null"
          ]
        },
        "settlementInstructionState": {
          "type": [
            "string",
            "null"
          ]
        },
        "settlementAction": {
          "type": [
            "string",
            "null"
          ]
        },
        "adapterReceiptStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "adapterMovementLotIds": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "finalPostReturnState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "returnState",
        "settlementInstructionState",
        "returnedLotIds",
        "remainingEncumberedLotIds",
        "returnedHoldingLotIds",
        "remainingHoldingLotIds",
        "providerVisibleAdapterReceiptCount"
      ],
      "properties": {
        "returnState": {
          "type": "string",
          "minLength": 1
        },
        "settlementInstructionState": {
          "type": [
            "string",
            "null"
          ]
        },
        "returnedLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "remainingEncumberedLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "returnedHoldingLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "remainingHoldingLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "providerVisibleAdapterReceiptCount": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "replayHandlingResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attempted",
        "result",
        "controlCheckId",
        "detail"
      ],
      "properties": {
        "attempted": {
          "type": "boolean"
        },
        "result": {
          "type": "string",
          "enum": [
            "NOT_REQUESTED",
            "BLOCKED_DUPLICATE_RETURN_REQUEST"
          ]
        },
        "controlCheckId": {
          "type": [
            "string",
            "null"
          ]
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "workflowStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step",
        "phase",
        "actor",
        "state",
        "detail"
      ],
      "properties": {
        "step": {
          "type": "integer",
          "minimum": 1
        },
        "phase": {
          "type": "string",
          "minLength": 1
        },
        "actor": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "type": "string",
          "minLength": 1
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "workflowExecutionReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reportId",
        "workflowType",
        "outcome",
        "summary",
        "eventIds",
        "eventStates"
      ],
      "properties": {
        "reportId": {
          "$ref": "#/$defs/identifier"
        },
        "workflowType": {
          "type": "string",
          "minLength": 1
        },
        "outcome": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "eventIds": {
          "$ref": "#/$defs/stringArray"
        },
        "eventStates": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "controlCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkId",
        "status",
        "detail"
      ],
      "properties": {
        "checkId": {
          "$ref": "#/$defs/identifier"
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "workflowResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenarioId",
        "obligationId",
        "returnRequestId",
        "correlationId",
        "workflowGate",
        "returnState",
        "securedPartyApproval",
        "custodianApproval",
        "settlementInstructionId",
        "settlementInstructionState",
        "currentEncumberedLotIds",
        "returnedLotIds",
        "remainingEncumberedLotIds",
        "requestedReturnQuantity",
        "currentSecuredAmount",
        "remainingRequiredCoverage",
        "releaseConditionSatisfied",
        "atomicityOutcome",
        "executionReportCount",
        "executionReports",
        "controlChecks",
        "steps"
      ],
      "properties": {
        "scenarioId": {
          "$ref": "#/$defs/identifier"
        },
        "obligationId": {
          "$ref": "#/$defs/identifier"
        },
        "returnRequestId": {
          "$ref": "#/$defs/identifier"
        },
        "correlationId": {
          "$ref": "#/$defs/identifier"
        },
        "workflowGate": {
          "type": [
            "string",
            "null"
          ]
        },
        "returnState": {
          "type": "string",
          "minLength": 1
        },
        "securedPartyApproval": {
          "type": "string",
          "minLength": 1
        },
        "custodianApproval": {
          "type": "string",
          "minLength": 1
        },
        "settlementInstructionId": {
          "type": [
            "string",
            "null"
          ]
        },
        "settlementInstructionState": {
          "type": [
            "string",
            "null"
          ]
        },
        "currentEncumberedLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "returnedLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "remainingEncumberedLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "requestedReturnQuantity": {
          "type": "number"
        },
        "currentSecuredAmount": {
          "type": "number"
        },
        "remainingRequiredCoverage": {
          "type": "number"
        },
        "releaseConditionSatisfied": {
          "type": "boolean"
        },
        "atomicityOutcome": {
          "type": "string",
          "enum": [
            "COMMITTED_ATOMICALLY",
            "BLOCKED_ATOMICALLY",
            "PENDING_ATOMIC_SETTLEMENT"
          ]
        },
        "executionReportCount": {
          "type": "integer",
          "minimum": 0
        },
        "executionReports": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/workflowExecutionReport"
          }
        },
        "controlChecks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/controlCheck"
          }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/workflowStep"
          }
        }
      }
    },
    "timelineEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sequence",
        "scenarioSequence",
        "scenarioId",
        "phase",
        "status",
        "startedAt",
        "finishedAt",
        "artifactPath",
        "detail"
      ],
      "properties": {
        "sequence": {
          "type": "integer",
          "minimum": 1
        },
        "scenarioSequence": {
          "type": "integer",
          "minimum": 1
        },
        "scenarioId": {
          "$ref": "#/$defs/identifier"
        },
        "phase": {
          "type": "string",
          "enum": [
            "POLICY_EVALUATION",
            "OPTIMIZATION",
            "QUICKSTART_SEED",
            "WORKFLOW",
            "ADAPTER"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "COMPLETED",
            "SKIPPED"
          ]
        },
        "startedAt": {
          "$ref": "#/$defs/dateTime"
        },
        "finishedAt": {
          "$ref": "#/$defs/dateTime"
        },
        "artifactPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "invariantCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "invariantId",
        "status",
        "evidence",
        "note"
      ],
      "properties": {
        "invariantId": {
          "$ref": "#/$defs/identifier"
        },
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL"
          ]
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/pathString"
          }
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
