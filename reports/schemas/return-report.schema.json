{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://canton-collateral-control-plane.dev/reports/return-report.schema.json",
  "title": "Return Report v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reportType",
    "reportVersion",
    "returnReportId",
    "generatedAt",
    "overallStatus",
    "demo",
    "artifacts",
    "scenarios",
    "timeline",
    "invariantChecks"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri-reference"
    },
    "reportType": {
      "const": "ReturnReport"
    },
    "reportVersion": {
      "const": "0.1.0"
    },
    "returnReportId": {
      "type": "string",
      "pattern": "^rrr-[0-9a-f]{16}$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "overallStatus": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "demo": {
      "$ref": "#/$defs/demo"
    },
    "artifacts": {
      "$ref": "#/$defs/artifacts"
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scenario"
      }
    },
    "timeline": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/timelineEntry"
      }
    },
    "invariantChecks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/invariantCheck"
      }
    }
  },
  "$defs": {
    "pathString": {
      "type": "string",
      "minLength": 1
    },
    "identifier": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "demo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "demoId",
        "demoVersion",
        "command",
        "manifestPath",
        "outputDirectory",
        "primaryOptimizationArtifact",
        "scenarioCount",
        "positiveScenarioCount",
        "negativeScenarioCount"
      ],
      "properties": {
        "demoId": {
          "$ref": "#/$defs/identifier"
        },
        "demoVersion": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "command": {
          "const": "make demo-return"
        },
        "manifestPath": {
          "$ref": "#/$defs/pathString"
        },
        "outputDirectory": {
          "$ref": "#/$defs/pathString"
        },
        "primaryOptimizationArtifact": {
          "$ref": "#/$defs/pathString"
        },
        "scenarioCount": {
          "type": "integer",
          "minimum": 1
        },
        "positiveScenarioCount": {
          "type": "integer",
          "minimum": 1
        },
        "negativeScenarioCount": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "returnReportPath",
        "markdownSummaryPath",
        "timelinePath"
      ],
      "properties": {
        "returnReportPath": {
          "$ref": "#/$defs/pathString"
        },
        "markdownSummaryPath": {
          "$ref": "#/$defs/pathString"
        },
        "timelinePath": {
          "$ref": "#/$defs/pathString"
        }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenarioId",
        "mode",
        "description",
        "result",
        "summary",
        "observedReasonCodes",
        "expectedReasonCodes",
        "policyEvaluationReportPath",
        "optimizationReportPath",
        "workflowInputPath",
        "workflowResultPath",
        "policyDecision",
        "optimizationStatus",
        "currentPostedLotIds",
        "retainedLotIds",
        "returnLotIds",
        "requestedReturnQuantity",
        "remainingRequiredCoverage",
        "workflow"
      ],
      "properties": {
        "scenarioId": {
          "$ref": "#/$defs/identifier"
        },
        "mode": {
          "type": "string",
          "enum": [
            "POSITIVE",
            "NEGATIVE"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "result": {
          "type": "string",
          "enum": [
            "SUCCESS",
            "EXPECTED_FAILURE"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "observedReasonCodes": {
          "$ref": "#/$defs/stringArray"
        },
        "expectedReasonCodes": {
          "$ref": "#/$defs/stringArray"
        },
        "policyEvaluationReportPath": {
          "$ref": "#/$defs/pathString"
        },
        "optimizationReportPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "workflowInputPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "workflowResultPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "policyDecision": {
          "type": "string",
          "enum": [
            "ACCEPT",
            "REJECT",
            "ESCALATE",
            "REVIEW"
          ]
        },
        "optimizationStatus": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "OPTIMAL",
            "NO_SOLUTION",
            null
          ]
        },
        "currentPostedLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "retainedLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "returnLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "requestedReturnQuantity": {
          "type": [
            "number",
            "null"
          ]
        },
        "remainingRequiredCoverage": {
          "type": [
            "number",
            "null"
          ]
        },
        "workflow": {
          "type": [
            "object",
            "null"
          ],
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/workflowResult"
            }
          ]
        }
      }
    },
    "workflowStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step",
        "phase",
        "actor",
        "state",
        "detail"
      ],
      "properties": {
        "step": {
          "type": "integer",
          "minimum": 1
        },
        "phase": {
          "type": "string",
          "minLength": 1
        },
        "actor": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "type": "string",
          "minLength": 1
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "workflowExecutionReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reportId",
        "workflowType",
        "outcome",
        "summary",
        "eventIds",
        "eventStates"
      ],
      "properties": {
        "reportId": {
          "$ref": "#/$defs/identifier"
        },
        "workflowType": {
          "type": "string",
          "minLength": 1
        },
        "outcome": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "eventIds": {
          "$ref": "#/$defs/stringArray"
        },
        "eventStates": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "controlCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkId",
        "status",
        "detail"
      ],
      "properties": {
        "checkId": {
          "$ref": "#/$defs/identifier"
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "workflowResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenarioId",
        "obligationId",
        "returnRequestId",
        "returnState",
        "securedPartyApproval",
        "custodianApproval",
        "currentEncumberedLotIds",
        "returnedLotIds",
        "remainingEncumberedLotIds",
        "requestedReturnQuantity",
        "currentSecuredAmount",
        "remainingRequiredCoverage",
        "releaseConditionSatisfied",
        "atomicityOutcome",
        "executionReportCount",
        "executionReports",
        "controlChecks",
        "steps"
      ],
      "properties": {
        "scenarioId": {
          "$ref": "#/$defs/identifier"
        },
        "obligationId": {
          "$ref": "#/$defs/identifier"
        },
        "returnRequestId": {
          "$ref": "#/$defs/identifier"
        },
        "returnState": {
          "type": "string",
          "minLength": 1
        },
        "securedPartyApproval": {
          "type": "string",
          "minLength": 1
        },
        "custodianApproval": {
          "type": "string",
          "minLength": 1
        },
        "currentEncumberedLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "returnedLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "remainingEncumberedLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "requestedReturnQuantity": {
          "type": "number"
        },
        "currentSecuredAmount": {
          "type": "number"
        },
        "remainingRequiredCoverage": {
          "type": "number"
        },
        "releaseConditionSatisfied": {
          "type": "boolean"
        },
        "atomicityOutcome": {
          "type": "string",
          "enum": [
            "COMMITTED_ATOMICALLY",
            "BLOCKED_ATOMICALLY"
          ]
        },
        "executionReportCount": {
          "type": "integer",
          "minimum": 0
        },
        "executionReports": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/workflowExecutionReport"
          }
        },
        "controlChecks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/controlCheck"
          }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/workflowStep"
          }
        }
      }
    },
    "timelineEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sequence",
        "scenarioSequence",
        "scenarioId",
        "phase",
        "status",
        "startedAt",
        "finishedAt",
        "artifactPath",
        "detail"
      ],
      "properties": {
        "sequence": {
          "type": "integer",
          "minimum": 1
        },
        "scenarioSequence": {
          "type": "integer",
          "minimum": 1
        },
        "scenarioId": {
          "$ref": "#/$defs/identifier"
        },
        "phase": {
          "type": "string",
          "enum": [
            "POLICY_EVALUATION",
            "OPTIMIZATION",
            "WORKFLOW"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "COMPLETED"
          ]
        },
        "startedAt": {
          "$ref": "#/$defs/dateTime"
        },
        "finishedAt": {
          "$ref": "#/$defs/dateTime"
        },
        "artifactPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "invariantCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "invariantId",
        "status",
        "evidence",
        "note"
      ],
      "properties": {
        "invariantId": {
          "$ref": "#/$defs/identifier"
        },
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL"
          ]
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/pathString"
          }
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
