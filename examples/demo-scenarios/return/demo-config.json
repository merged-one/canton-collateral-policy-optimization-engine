{
  "demoId": "return-prototype",
  "demoVersion": "0.1.0",
  "scenarios": [
    {
      "scenarioId": "positive-return",
      "mode": "POSITIVE",
      "description": "Excess collateral is identified from the currently encumbered set, approvals are enforced, and the selected lot is returned while the retained lots remain pledged.",
      "policy": "return-policy.json",
      "inventory": "positive-inventory.json",
      "obligation": "positive-obligation.json",
      "runOptimization": true,
      "runWorkflow": true,
      "workflow": {
        "scriptName": "CantonCollateral.Demo:returnDemoWorkflow",
        "returnRequestId": "ret-request-positive",
        "correlationId": "corr-return-demo-001",
        "custodyAccount": "acct-provider-return-pledge-window",
        "sourceAccount": "acct-secured-return-demo",
        "destinationAccount": "acct-provider-return-demo",
        "settlementSystem": "Fedwire",
        "tokenAdapterReferencePrefix": "demo/adapter",
        "transferabilityFlags": [
          "deliverable",
          "pledgeable",
          "segregated"
        ]
      },
      "expected": {
        "policyOverallDecision": "ACCEPT",
        "optimizationStatus": "OPTIMAL",
        "workflowReturnState": "Closed",
        "currentEncumberedLotIds": [
          "ret-current-ust",
          "ret-current-fannie",
          "ret-current-kfw"
        ],
        "returnedLotIds": [
          "ret-current-ust"
        ],
        "remainingEncumberedLotIds": [
          "ret-current-fannie",
          "ret-current-kfw"
        ],
        "releaseConditionSatisfied": true,
        "atomicityOutcome": "COMMITTED_ATOMICALLY",
        "minimumExecutionReportCount": 1,
        "reasonCodes": []
      }
    },
