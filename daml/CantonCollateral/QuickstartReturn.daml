module CantonCollateral.QuickstartReturn where

import Daml.Script

import CantonCollateral.Encumbrance
import CantonCollateral.Inventory
import CantonCollateral.QuickstartAdapter
import CantonCollateral.QuickstartSeed
import CantonCollateral.ReferenceToken
import CantonCollateral.Report
